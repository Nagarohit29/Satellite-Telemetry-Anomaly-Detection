# Git
.git
.gitignore

# Python
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
ENV/
env/

# .env files — NEVER bake real API keys into the image.
# The Dockerfiles create seed .env files via RUN printf commands.
# docker-compose mounts the real .env at runtime: - .env:/app/.env
.env
Middleware/.env

# Node.js
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm/
Frontend/*
!Frontend/dist/
!Frontend/dist/**
!Frontend/nginx.monolith.conf
!Frontend/nginx.conf

# Build artifacts
dist/
build/
.next/
out/
!Frontend/dist/
!Frontend/dist/**

# Data and Models. Keep large datasets/results out of the image, but include
# only the replay dataset and checkpoint needed for zero-config inference.
Backend/data/*
!Backend/data/SMAP_MSL/
!Backend/data/SMAP_MSL/**
Backend/models/
Backend/results/
Backend/processed/
Backend/plots/
Backend/checkpoints/
!Backend/checkpoints/
!Backend/checkpoints/TranAD_SMAP/
!Backend/checkpoints/TranAD_SMAP/model.ckpt

# Notebooks and scratch files
notebooks/
scratch/
Backend/scratch/
Backend/plots/

# OS files
.DS_Store
Thumbs.db
.codex_tmp/
docs/

# Docker files (not needed in build context)
docker-compose*
.dockerignore
