# Git
.git
.gitignore

# Python
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
ENV/
env/

# .env files — NEVER bake real API keys into the image.
# The Dockerfiles create seed .env files via RUN printf commands.
# docker-compose mounts the real .env at runtime: - .env:/app/.env
.env
Middleware/.env

# Node.js
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm/

# Build artifacts
dist/
build/
.next/
out/

# Data and Models. Keep large datasets/results out of the image, but include
# the trained checkpoint needed for zero-config inference.
Backend/data/train/
Backend/data/test/
Backend/models/
Backend/results/
Backend/checkpoints/
!Backend/checkpoints/
!Backend/checkpoints/TranAD_SMAP/
!Backend/checkpoints/TranAD_SMAP/model.ckpt

# Notebooks and scratch files
notebooks/
scratch/
Backend/scratch/
Backend/plots/

# OS files
.DS_Store
Thumbs.db

# Docker files (not needed in build context)
docker-compose*
.dockerignore
