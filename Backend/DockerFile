# Build stage for Backend
FROM nvidia/cuda:12.1.0-cudnn8-runtime-ubuntu22.04

# Metadata labels for Docker Hub
LABEL maintainer="Satellite Telemetry Anomaly Detection Team"
LABEL version="1.0"
LABEL description="Backend AI Inference Engine for Satellite Telemetry Anomaly Detection"

WORKDIR /app

# Prevent interactive prompts during build
ENV DEBIAN_FRONTEND=noninteractive
ENV PYTHONUNBUFFERED=1

# Install system dependencies
RUN apt-get update && apt-get install -y \
    python3 \
    python3-pip \
    python3-dev \
    && rm -rf /var/lib/apt/lists/*

# Create python alias
RUN ln -s /usr/bin/python3 /usr/bin/python

# Copy requirements from root context
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Copy only Backend files from the root context
COPY Backend/ .

# Ensure data and models directories exist
RUN mkdir -p data models results checkpoints

EXPOSE 8001

# Run the inference server
CMD ["python", "serve.py"]